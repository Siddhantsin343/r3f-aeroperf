{
  "name": "r3f-aeroperf",
  "version": "0.0.3",
  "description": "A lightweight performance measurement library for Three.js and React Three Fiber, supporting WebGL and WebGPU.",
  "keywords": [
    "react",
    "three",
    "threejs",
    "react-three-fiber",
    "r3f",
    "webgl",
    "webgpu",
    "performance",
    "stats",
    "monitor",
    "aeroperf"
  ],
  "author": "Siddhant Singh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Siddhantsin343/r3f-aeroperf.git"
  },
  "bugs": {
    "url": "https://github.com/Siddhantsin343/r3f-aeroperf/issues"
  },
  "homepage": "https://github.com/Siddhantsin343/r3f-aeroperf#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "cross-env BUILD_LIB=true vite build && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\"",
    "build:demo": "vite build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "valtio": "^2.1.0"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8.0",
    "react": ">=18.0",
    "react-dom": ">=18.0",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "vite": "^5.4.0",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}